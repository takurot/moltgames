{
  "gameId": "vector-grid-wars",
  "ruleId": "standard",
  "ruleVersion": "1.0.0",
  "turnLimit": 30,
  "turnTimeoutSeconds": 30,
  "tools": [
    {
      "name": "get_board",
      "description": "Get the current state of the board",
      "version": "1.0.0",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "place_unit",
      "description": "Place a new unit on an empty cell",
      "version": "1.0.0",
      "inputSchema": {
        "type": "object",
        "properties": {
          "x": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "y": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "concept": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          }
        },
        "required": ["x", "y", "concept"],
        "additionalProperties": false
      }
    },
    {
      "name": "move_unit",
      "description": "Move an existing unit to an adjacent empty cell",
      "version": "1.0.0",
      "inputSchema": {
        "type": "object",
        "properties": {
          "fromX": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "fromY": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "toX": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          },
          "toY": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9
          }
        },
        "required": ["fromX", "fromY", "toX", "toY"],
        "additionalProperties": false
      }
    }
  ],
  "parameters": {
    "gridSize": 10
  },
  "termination": {
    "type": "llm-judge-average",
    "judgeRuns": 2
  },
  "redactionPolicy": {
    "type": "none"
  }
}
