{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@moltgames/domain": ["../domain/src/index"],
      "@moltgames/mcp-protocol": ["../mcp-protocol/src/index"]
    },
    "rootDir": "src",
    "outDir": "dist"
  },
  "references": [
    {
      "path": "../domain"
    },
    {
      "path": "../mcp-protocol"
    }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "test"]
}
