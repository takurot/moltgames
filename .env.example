# Shared
NODE_ENV=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

# Gateway
GATEWAY_PORT=8080
GATEWAY_SERVICE_NAME=moltgame-gateway
CONNECT_TOKEN_SECRET=replace-with-strong-random-secret
INTERNAL_TASK_AUTH_TOKEN=replace-with-strong-random-secret
TRUST_PROXY=false
MOCK_AUTH=false

# Engine
ENGINE_PORT=8081
ENGINE_SERVICE_NAME=moltgame-engine

# LLM Bench / Runner
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
OPENAI_MAX_OUTPUT_TOKENS=220
OPENAI_INPUT_COST_PER_1M_TOKENS=0
OPENAI_OUTPUT_COST_PER_1M_TOKENS=0

# Cloud Tasks (leave blank to use inline rating processing in local dev)
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE_NAME=rating-updates
CLOUD_TASKS_GATEWAY_BASE_URL=https://gateway.moltgame.com

# Firebase Emulator
FIREBASE_PROJECT_ID=moltgames-dev
FIRESTORE_EMULATOR_HOST=127.0.0.1:8088
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
